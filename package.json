{
  "name": "ai-admin",
  "version": "0.1.2",
  "description": "AI Admin — Telegram channel content processing bot on Cloudflare Workers. Free, serverless, AI-powered.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "fix:webhook": "node scripts/fix-webhook.mjs",
    "test:units": "node scripts/test-units.mjs",
    "test:pipeline": "node scripts/test-pipeline.mjs",
    "test:admin": "node scripts/test-admin.mjs",
    "test:debug": "node scripts/test-debug.mjs && node scripts/test-debug-html.mjs",
    "test": "node scripts/test-units.mjs && node scripts/test-pipeline.mjs && node scripts/test-admin.mjs && node scripts/test-debug.mjs && node scripts/test-debug-html.mjs"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "telegram-bot",
    "cloudflare-workers",
    "ai",
    "gemini",
    "openrouter",
    "content-processing",
    "serverless"
  ],
  "license": "MIT"
}
