# ============================================================
# .dev.vars — LOCAL DEVELOPMENT ONLY
# ============================================================
# Copy this file to `.dev.vars` and fill in real values for local testing.
# NEVER commit your real `.dev.vars` file.
#
# In production, set ALL of these as Cloudflare Secrets via the dashboard:
#   Workers & Pages → ai-admin → Settings → Variables and Secrets
# ============================================================

# === Secrets (required) ===
BOT_TOKEN=123456:ABC-DEF-your-telegram-bot-token
GEMINI_API_KEY=your-google-gemini-api-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# === Optional: webhook secret for verifying Telegram requests ===
# WEBHOOK_SECRET=any-random-string-here

# === Vars (also set in dashboard OR wrangler.toml) ===
# ADMIN_ID=123456789
# TARGET_CHANNEL=@your_channel
# FOOTER_TEXT=🌀 @ILIVIR3
# DEFAULT_AI_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.0-flash
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
